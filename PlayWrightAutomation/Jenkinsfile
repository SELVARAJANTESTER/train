pipeline {
    agent any

    parameters {
        choice(name: 'TEST_TYPE', choices: ['regression', 'webTests', 'APITests'], description: 'Select test type to run')
        string(name: 'BRANCH', defaultValue: 'main', description: 'Git branch to test')
    }

    environment {
        NODE_PATH = 'C:\\Program Files\\nodejs'
        GIT_REPO = 'https://github.com/YOUR_GITHUB_USERNAME/PlayWrightAutomation.git'
        PROJECT_DIR = 'PlayWrightAutomation'
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    echo "Checking out branch: ${params.BRANCH}"
                    checkout(
                        [
                            $class: 'GitSCM',
                            branches: [[name: "*/${params.BRANCH}"]],
                            userRemoteConfigs: [[url: "${env.GIT_REPO}"]]
                        ]
                    )
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                script {
                    dir("${env.PROJECT_DIR}") {
                        echo "Installing Node.js dependencies..."
                        bat 'npm install'
                    }
                }
            }
        }

        stage('Run Tests') {
            steps {
                script {
                    dir("${env.PROJECT_DIR}") {
                        echo "Running ${params.TEST_TYPE} tests..."
                        bat "npm run ${params.TEST_TYPE}"
                    }
                }
            }
        }

        stage('Generate Allure Report') {
            steps {
                script {
                    dir("${env.PROJECT_DIR}") {
                        echo "Generating Allure report..."
                        bat '''
                            if exist allure-results (
                                allure generate allure-results -c -o allure-report
                            )
                        '''
                    }
                }
            }
        }

        stage('Archive Results') {
            steps {
                script {
                    dir("${env.PROJECT_DIR}") {
                        archiveArtifacts artifacts: 'playwright-report/**', allowEmptyArchive: true
                        archiveArtifacts artifacts: 'test-results/**', allowEmptyArchive: true
                        archiveArtifacts artifacts: 'allure-report/**', allowEmptyArchive: true
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                echo "Cleaning up..."
                deleteDir()
            }
        }

        success {
            echo "✓ Pipeline completed successfully!"
        }

        failure {
            echo "✗ Pipeline failed. Check logs for details."
        }
    }
}
